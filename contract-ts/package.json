{
  "name": "counter",
  "version": "2.0.0",
  "license": "(MIT AND Apache-2.0)",
  "type": "module",
  "scripts": {
    "build": "near-sdk-js build src/contract.ts build/counter.wasm",
    "test": "$npm_execpath run build && ava --serial -- ./build/counter.wasm"
  },
  "dependencies": {
    "near-sdk-js": "2.0.0"
  },
  "devDependencies": {
    "ava": "^8.0.1",
    "near-api-js": "^7.2.0",
    "near-sandbox": "^0.3.1",
    "typescript": "^5.9.3"
  },
  "ava": {
    "timeout": "60000",
    "files": [
      "sandbox-test/*.ava.js"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "near-sdk-js",
      "near-sandbox"
    ]
  }
}
